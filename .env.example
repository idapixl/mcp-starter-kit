# MCP Server Configuration
# Copy this file to .env and fill in your values

# Server identity
SERVER_NAME=my-mcp-server
SERVER_VERSION=1.0.0

# Web Fetcher Tool
# Max size of fetched content in bytes (default: 1MB)
FETCH_MAX_BYTES=1048576
# Request timeout in milliseconds (default: 10s)
FETCH_TIMEOUT_MS=10000
# Comma-separated list of blocked domains (optional)
FETCH_BLOCKED_DOMAINS=

# File Reader Tool
# Root directory that the file reader is allowed to access
# IMPORTANT: Restrict this to a safe directory — never set to / or C:\
FILE_READER_ROOT=./workspace

# Data Transformer Tool
# Maximum input size in characters
TRANSFORMER_MAX_INPUT=50000

# Logging
# Options: debug, info, warn, error
LOG_LEVEL=info
