{
  "name": "@idapixl/mcp-starter-kit",
  "version": "1.0.0",
  "description": "Production-ready MCP server template with example tools, TypeScript, and best practices",
  "mcpName": "io.github.idapixl/mcp-starter-kit",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "tools",
    "typescript"
  ],
  "author": "IDAPIXL",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/idapixl/mcp-starter-kit.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
